# Copy to .env and fill in real values:
#   copy .env.example .env
#
# Never commit .env — it is listed in .gitignore.

# MongoDB (Atlas connection string or local):
# MONGODB_URI=mongodb://127.0.0.1:27017/unihostel
MONGODB_URI=

# Optional: custom DNS for mongodb+srv if SRV lookups fail (comma-separated).
# MONGODB_DNS_SERVERS=8.8.8.8,8.8.4.4

JWT_SECRET=change-me-to-a-long-random-string

PORT=5001

# --- OTP emails (Gmail) — required for "Forgot password" and student signup OTP ---
# Use the SAME Google account for both. EMAIL_PASS must be an App Password, not your login password:
# Google Account → Security → 2-Step Verification → App passwords → create "Mail" for this app.
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=xxxx xxxx xxxx xxxx

# Local dev only: if EMAIL_* are unset, OTPs are printed in the backend terminal instead of email.
# DEV_OTP_TO_CONSOLE=1
