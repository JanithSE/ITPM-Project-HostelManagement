# Copy to .env and fill in real values:
#   copy .env.example .env
#
# Never commit .env — it is listed in .gitignore.

# MongoDB (Atlas connection string or local):
# MONGODB_URI=mongodb://127.0.0.1:27017/unihostel
MONGODB_URI=

# Optional: custom DNS for mongodb+srv if SRV lookups fail (comma-separated).
# MONGODB_DNS_SERVERS=8.8.8.8,8.8.4.4

JWT_SECRET=change-me-to-a-long-random-string

PORT=5001

# --- Email transport ---
# OTP / registration email: `authController` uses only these (Gmail + App Password):
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=xxxx xxxx xxxx xxxx
#
# General transactional mail (bookings, documents): preferred generic SMTP; else falls back to EMAIL_*.
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@domain.com
# SMTP_PASS=your-smtp-or-app-password
# SMTP_FROM=Hostel Management <you@domain.com>
#
# Payment confirmed / payment rejected only (optional second account). If unset, uses SMTP_* or EMAIL_* above.
# Gmail example (use App Password, 2-Step Verification on that account):
# PAYMENT_SMTP_HOST=smtp.gmail.com
# PAYMENT_SMTP_PORT=587
# PAYMENT_SMTP_SECURE=false
# PAYMENT_SMTP_USER=finance@example.com
# PAYMENT_SMTP_PASS=xxxx xxxx xxxx xxxx
# PAYMENT_SMTP_FROM=UniHostel Finance <finance@example.com>

# Local dev only: if EMAIL_* are unset, OTPs are printed in the backend terminal instead of email.
# DEV_OTP_TO_CONSOLE=1

# --- Booking AI Chat ---
# Leave AI_PROVIDER and AI_API_KEY empty to run rules-only mode.
# AI_PROVIDER=openai
# AI_API_KEY=
# AI_MODEL=gpt-4o-mini
# AI_TIMEOUT_MS=8000
# AI_RULES_CONFIDENCE=0.85
# AI_RATE_WINDOW_MS=60000
# AI_RATE_MAX_REQUESTS=10
# AI_DAILY_CHAT_LIMIT=80
# Roommate search in booking chat: show student names, or only counts
# CHAT_ROOMMATE_DETAIL=names
# CHAT_ROOMMATE_DETAIL=counts
